# Copy backend variables to backend/.env and frontend variables to frontend/.env.
# Never commit real environment files.

# Backend
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://yommi_local:local_only_change_me@localhost:5432/yommi?schema=public
JWT_SECRET=replace_with_at_least_32_random_characters
API_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=
UPLOAD_DIR=uploads
STORAGE_DRIVER=local

# Frontend (public build-time values only)
VITE_API_URL=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=