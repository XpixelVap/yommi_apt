{
  "name": "yommi-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node server.js",
    "build": "esbuild server.ts --bundle --platform=node --target=node18 --format=esm --outfile=server.js --packages=external",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/tests/regression.test.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.31.1",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}