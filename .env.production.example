# Copy to .env.production on the VPS and replace every CHANGE_ME value.
# This file contains placeholders only. Never use it as production credentials.
NODE_ENV=production
TZ=America/Tijuana

POSTGRES_DB=yommigo
POSTGRES_USER=yommigo_app
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DATABASE_PASSWORD
# Password must be URL-encoded here when it contains reserved URI characters.
# Host must remain "postgres" inside Docker Compose.
DATABASE_URL=postgresql://yommigo_app:CHANGE_ME_URL_ENCODED_DATABASE_PASSWORD@postgres:5432/yommigo?schema=public

JWT_SECRET=CHANGE_ME
API_URL=https://api.yommigo.com
CORS_ORIGINS=https://yommigo.com,https://www.yommigo.com
STORAGE_DRIVER=disabled
UPLOAD_DIR=/app/uploads
GOOGLE_CLIENT_ID=
GEMINI_API_KEY=

# Public values embedded into the frontend image at build time.
VITE_API_URL=https://api.yommigo.com
VITE_GOOGLE_CLIENT_ID=

FRONTEND_DOMAIN=yommigo.com
WWW_DOMAIN=www.yommigo.com
API_DOMAIN=api.yommigo.com
LETSENCRYPT_EMAIL=CHANGE_ME_OPERATIONS_EMAIL
